{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "types": ["node"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@web3viz/core": ["./packages/core/src/index.ts"],
      "@web3viz/core/*": ["./packages/core/src/*/index.ts"],
      "@web3viz/providers": ["./packages/providers/src/index.ts"],
      "@web3viz/providers/*": ["./packages/providers/src/*/index.ts"],
      "@web3viz/react-graph": ["./packages/react-graph/src/index.ts"],
      "@web3viz/ui": ["./packages/ui/src/index.ts"],
      "@web3viz/ui/*": ["./packages/ui/src/*/index.ts"],
      "@web3viz/utils": ["./packages/utils/src/index.ts"],
      "@swarming/engine": ["./packages/engine/src/index.ts"],
      "@swarming/react": ["./packages/react/src/index.ts"],
      "@swarming/vue": ["./packages/vue/src/index.ts"],
      "@swarming/svelte": ["./packages/svelte/src/index.ts"],
      "@swarming/react-native": ["./packages/react-native/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "packages/executor", "apps/playground", "packages/react-native", "apps/mobile-demo", "packages/create-swarming-app", "packages/create-swarming-plugin", "packages/swarming", "packages/engine", "packages/react", "packages/vue", "packages/svelte", "providers", "temp", "extracted", "scripts", "benchmarks"]
}
