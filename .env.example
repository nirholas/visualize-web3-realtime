# ─── AI ───
# Required for /world AI chat (Groq — Llama 3.3 70B)
GROQ_API_KEY=

# ─── Blockchain Providers ───
# Solana RPC WebSocket (e.g. Helius, Alchemy)
NEXT_PUBLIC_SOLANA_WS_URL=

# Ethereum RPC WebSocket (fallback: wss://ethereum-rpc.publicnode.com)
NEXT_PUBLIC_ETH_WS_URL=

# Base RPC WebSocket (fallback: wss://base-rpc.publicnode.com)
NEXT_PUBLIC_BASE_WS_URL=

# ─── SperaxOS Agent API ───
# WebSocket endpoint for real-time agent events
NEXT_PUBLIC_SPERAXOS_WS_URL=wss://api.speraxos.io/agents/v1/stream

# SperaxOS API key (leave empty to use mock data)
NEXT_PUBLIC_SPERAXOS_API_KEY=

# Set to 'false' to use real SperaxOS data (requires NEXT_PUBLIC_SPERAXOS_API_KEY)
# Defaults to 'true' (mock mode) when no API key is configured
NEXT_PUBLIC_AGENT_MOCK=true

# ─── Executor ───
# URL of the executor backend (used by the /api/executor proxy)
EXECUTOR_URL=http://localhost:8765

# WebSocket server (for the packages/executor backend)
EXECUTOR_PORT=8765
EXECUTOR_MAX_AGENTS=5
SPERAXOS_URL=https://api.speraxos.io
SPERAXOS_API_KEY=
STATE_PATH=./data/executor.db

# ─── X402 Payment Protocol ───
# Public URL for the app (used in x402-manifest)
NEXT_PUBLIC_APP_URL=https://visualize-web3.app

# Wallet address to receive payments (set to a real address before deploying)
X402_PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000

# Base Sepolia RPC URL (fallback: https://sepolia.base.org)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Session signing secret (change in production)
X402_SESSION_SECRET=change-me-in-production

# ─── X402 Payment Protocol ───
# Base Sepolia RPC URL for payment verification
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Recipient address for x402 payments (USDC on Base)
X402_PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000

# Secret used to sign/verify x402 session tokens
X402_SESSION_SECRET=change-me-in-production
