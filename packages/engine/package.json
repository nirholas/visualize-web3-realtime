{
  "name": "@swarming/engine",
  "version": "0.1.0",
  "description": "Framework-agnostic force-directed graph engine for swarming visualizations",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "keywords": [
    "3d", "force-graph", "visualization", "webgl", "three",
    "network", "graph", "swarming", "realtime", "engine"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "d3-force-3d": "^3.0.6",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/three": "^0.169.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
